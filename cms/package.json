    "@strapi/plugin-graphql": "5.0.0-beta.5",
    "@strapi/plugin-i18n": "5.0.0-beta.5",
    "@strapi/plugin-upload": "5.0.0-beta.5",
    "@strapi/plugin-users-permissions": "5.0.0-beta.5",
    "@strapi/provider-upload-local": "5.0.0-beta.5",
    "@strapi/strapi": "5.0.0-beta.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.30.1",
    "styled-components": "5.2.1",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5"
  },
  "overrides": {
    "@strapi/admin": "5.0.0-beta.5",
