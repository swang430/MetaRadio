{
  "name": "metaradio-cms",
  "version": "0.1.0",
  "private": true,
  "description": "Strapi v5 project for MetaRadio content automation",
  "engines": {
    "node": ">=18.0.0 <=20.x"
  },
  "scripts": {
    "develop": "node scripts/dev.js",
    "start": "strapi start",
    "build": "strapi build && node scripts/copy-static.js",
